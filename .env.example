# ===== 运行模式 =====
# sqlite=local file database / mysql=remote or docker MySQL
DB_MODE=mysql
# fake=in-memory Redis emulator / redis=real Redis service
MEMORY_MODE=redis

# SQLite file path (only used when DB_MODE=sqlite)
SQLITE_PATH=./coffee.db

# ===== MySQL (used when DB_MODE=mysql) =====
MYSQL_HOST=your-db-host
MYSQL_PORT=3306
MYSQL_USER=your-db-user
MYSQL_PASSWORD=your-db-password
MYSQL_DATABASE=your-db-name
MYSQL_ROOT_PASSWORD=your-mysql-root-password

# ===== Redis (used when MEMORY_MODE=redis) =====
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== LLM (OpenAI-compatible provider) =====
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ===== Chat memory =====
CHAT_HISTORY_ROUNDS=5
CHAT_HISTORY_TTL=1800
