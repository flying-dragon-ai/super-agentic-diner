# ===== Local storage defaults =====
ENVIRONMENT=local
# Comma-separated. Leave empty in production for same-origin-only requests.
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
DB_MODE=sqlite
SQLITE_PATH=coffee_ai.db
SQLITE_BUSY_TIMEOUT_MS=5000
USE_FAKEREDIS=true

# Demo seed data is opt-in. Never enable this in production.
SEED_DEMO_DATA=false

# ===== MySQL (only when DB_MODE=mysql) =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=coffee
MYSQL_PASSWORD=your-db-password
MYSQL_DATABASE=coffee_ai
MYSQL_ROOT_PASSWORD=your-mysql-root-password

# ===== Redis (only when USE_FAKEREDIS=false) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_CONNECT_TIMEOUT=3
REDIS_SOCKET_TIMEOUT=5

# ===== LLM (OpenAI-compatible provider) =====
# Fill one of LLM_API_KEY / DEEPSEEK_API_KEY / OPENAI_API_KEY.
LLM_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# Accepts either provider root URL ending in /v1 or the full /v1/chat/completions endpoint.
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# 兜底总超时（秒）；下方分段超时优先用于意图/生成/评审各阶段
LLM_TIMEOUT_SECONDS=15
LLM_CONNECT_TIMEOUT_SECONDS=3
LLM_INTENT_TIMEOUT_SECONDS=4
LLM_GENERATION_TIMEOUT_SECONDS=12
LLM_REVIEW_TIMEOUT_SECONDS=6

# ===== Chat memory =====
CHAT_HISTORY_ROUNDS=5
CHAT_HISTORY_TTL=1800

# ===== Visualization realtime fan-out =====
# Multi-worker / multi-instance WebSocket sync requires USE_FAKEREDIS=false.
VISUALIZATION_REDIS_CHANNEL=coffee:visualization:events
VISUALIZATION_CONNECTION_QUEUE_SIZE=100
VISUALIZATION_SEND_TIMEOUT_MS=500
VISUALIZATION_PRESENCE_TTL_SECONDS=45
VISUALIZATION_SKILL_SWEEP_LOCK_TTL_SECONDS=75

# ===== Autonomous digital customer =====
AUTONOMOUS_AGENT_ENABLED=true
AUTONOMOUS_AGENT_INTERVAL_MIN_SECONDS=45
AUTONOMOUS_AGENT_INTERVAL_MAX_SECONDS=75
AUTONOMOUS_AGENT_STEP_INTERVAL_SECONDS=4
AUTONOMOUS_AGENT_STATUS_TTL_SECONDS=180

# ===== EvoMap A2A service-order payments =====
SKILL_FREE_ORDER_LIMIT=2
EVOMAP_PAYMENT_MODE=service_order
EVOMAP_HUB_URL=https://evomap.ai
EVOMAP_SERVICE_LISTING_ID=your-evomap-service-listing-id
EVOMAP_NODE_ID=
EVOMAP_NODE_SECRET=
EVOMAP_GUILD_ID=
EVOMAP_ORDER_CREDITS=1
EVOMAP_REQUEST_TIMEOUT_SECONDS=15
SKILL_PAYMENT_PROCESSING_TIMEOUT_SECONDS=120
SKILL_RECONCILE_ENABLED=true
SKILL_RECONCILE_INTERVAL_SECONDS=60
SKILL_RECONCILE_BATCH_SIZE=10
SKILL_RECONCILE_CLAIM_TIMEOUT_SECONDS=300
EVOMAP_CREDIT_RATE=1
EVOMAP_ATP_CAPS=a2a_super_order,coffee_order
WORKER_ENABLED=0
WORKER_DOMAINS=a2a_super_order,coffee_order,crossroads_agent_cafe
WORKER_MAX_LOAD=5

# ===== Auth (账号结算、私有记录与在线顾客 presence) =====
# 匿名访客可浏览和准备待确认订单；确认扣款、私有订单/历史及管理接口必须登录。
# 生产环境务必把 AUTH_SECRET_KEY 改成一串足够长的随机字符串；下方占位值会被拒绝。
AUTH_SECRET_KEY=change-me-to-a-random-long-string-in-production
AUTH_COOKIE_NAME=coffee_session
AUTH_COOKIE_MAX_AGE_SECONDS=604800
AUTH_COOKIE_SECURE=false
REGISTRATION_BONUS_CNY=50.00
ALLOW_REGISTRATION_BONUS_IN_PRODUCTION=false
# Optional username consumed only by scripts/bootstrap_admin.py.
ADMIN_BOOTSTRAP_USERNAME=
