# Docker build context exclusions.
# Runtime image only needs app/ (including app/static/3d), scripts/, and requirements.txt.

# VCS
.git/
.gitignore
.gitattributes

# Python caches and local virtual environments
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/

# Frontend source/dependencies are excluded; built output is served from app/static/3d.
frontend/
package.json
package-lock.json

# AI editor and local tool config, not needed in runtime images
.idea/
.cursor/
.codex/
.gemini/
.trae/
.zhipu/
.qingyan/
.kiro/
.codestable/
.claude/
.evolver/
.codegraph/
.ccg/
.agents/
.context/
.opencode/

# Docs, tests, and local verification artifacts
docs/
tests/
*.md
memory/
output/
.artifacts/
.playwright-mcp/

# Local credentials: inject via environment variables or platform secrets
.env
.env.*
.local-consumer.env
.mcp.json
.mcp.json.backup

# Local runtime artifacts
*.log
server.*.log
coffee.db
coffee_ai.db
*.db
*.db-shm
*.db-wal

# Docker build files are not needed inside the image
deploy/
Dockerfile
.dockerignore
docker-compose.yml
