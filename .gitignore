# Python virtual environments and caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Local runtime data and secrets
.env
.env.*
!.env.example
coffee.db
coffee_ai.db
logs/
*.log
server.*.log

# Node dependencies and local build caches
node_modules/

# Browser/tooling/runtime evidence generated during local verification
.artifacts/
.playwright-mcp/
output/

# CodeGraph local index/runtime files. Keep source docs/config if added later.
.codegraph/*.db*
.codegraph/*.log
.codegraph/*.pid

# EvoMap/Evolver local runtime memory
.evolver/gep/*.jsonl
.evolver/gep/failed_capsules.json
memory/evolution/
memory/evolver_update_check.json
memory/atp-autobuy-ack.json
memory/atp-autobuyer-ledger.json

# Local task-runner transcripts
.ccg/tasks/archive/
.ccg/tasks/*/.turns.json
.ccg/tasks/*/context.jsonl

# Local EvoMap consumer credentials for paid Skill testing
.local-consumer.env

# Local MCP backups may contain machine-specific paths or credentials
.mcp.json.backup

# Personal AI editor / IDE configs
.idea/
.cursor/
.codex/
.gemini/
.trae/
.zhipu/
.qingyan/
.kiro/

# Local verification screenshots / smoke artifacts
smoke-*.png
3d-scene-*.png

# Root-level evolver-only node manifest; frontend/package.json is tracked
/package.json
/package-lock.json

# Claude Code personal settings; shared commands/hooks/skills remain tracked
.claude/settings.local.json
.claude/settings.local.json.backup

# SQLite runtime sidecar files. Main local DB files are ignored above.
*.db-shm
*.db-wal

# SSH public-tunnel runtime state (start-public.ps1 / stop-public.ps1)
.tunnel-pids.json

# OS metadata
.DS_Store
Thumbs.db

# Python test coverage
.coverage
htmlcov/

# Frontend local build caches; frontend/dist is covered by frontend/.gitignore
.vite/
build/

# Local gltfjsx scratch outputs; tracked generated models remain explicit.
frontend/src/office3d/generated/*Model.tsx
frontend/src/office3d/generated/index.ts
!frontend/src/office3d/generated/TableModel.tsx
