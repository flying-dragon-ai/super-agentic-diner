# ===== Runtime modes =====
# sqlite=local file database / mysql=remote or docker MySQL
DB_MODE=mysql
# fake=in-memory Redis emulator / redis=real Redis service
MEMORY_MODE=redis

# SQLite file path (only used when DB_MODE=sqlite)
SQLITE_PATH=./coffee.db

# ===== MySQL (used when DB_MODE=mysql) =====
MYSQL_HOST=47.93.176.175
MYSQL_PORT=3306
MYSQL_USER=coffee
MYSQL_PASSWORD=coffee123
MYSQL_DATABASE=coffee_ai
MYSQL_ROOT_PASSWORD=root123

# ===== Redis (used when MEMORY_MODE=redis) =====
REDIS_HOST=47.93.176.175
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== LLM (OpenAI-compatible provider) =====
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# ===== Chat memory =====
CHAT_HISTORY_ROUNDS=5
CHAT_HISTORY_TTL=1800
