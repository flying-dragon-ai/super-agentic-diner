# ===== 运行模式 =====
# sqlite=零依赖演示（文件数据库） / mysql=真实环境（需先 docker-compose up）
DB_MODE=sqlite
# fake=进程内模拟Redis（无需Redis） / redis=真实环境
MEMORY_MODE=fake

# SQLite 文件路径（DB_MODE=sqlite 时生效）
SQLITE_PATH=./coffee.db

# ===== MySQL（DB_MODE=mysql 时生效）=====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=coffee
MYSQL_PASSWORD=coffee123
MYSQL_DATABASE=coffee_ai
MYSQL_ROOT_PASSWORD=root123

# ===== Redis（MEMORY_MODE=redis 时生效）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== LLM（智谱 GLM，OpenAI 兼容）=====
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# ===== 对话记忆 =====
CHAT_HISTORY_ROUNDS=5
CHAT_HISTORY_TTL=1800
