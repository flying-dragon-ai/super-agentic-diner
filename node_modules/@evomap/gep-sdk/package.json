{
  "name": "@evomap/gep-sdk",
  "version": "1.5.0",
  "description": "Single source of truth for the Genome Evolution Protocol (GEP): JSON Schemas, specification, and protocol-level helpers (canonicalize / computeAssetId / verifyAssetId).",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./content-hash": "./src/contentHash.js",
    "./schemas/gene.schema.json": "./schemas/gene.schema.json",
    "./schemas/capsule.schema.json": "./schemas/capsule.schema.json",
    "./schemas/evolution-event.schema.json": "./schemas/evolution-event.schema.json",
    "./schemas/mutation.schema.json": "./schemas/mutation.schema.json",
    "./schemas/task.schema.json": "./schemas/task.schema.json",
    "./spec/gep-spec-v1.md": "./spec/gep-spec-v1.md"
  },
  "keywords": ["gep", "protocol", "schema", "ai-agent", "evolution", "self-evolution", "mcp", "evomap"],
  "files": [
    "src",
    "schemas",
    "spec",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "author": "EvoMap",
