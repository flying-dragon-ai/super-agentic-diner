  "repository": {
    "type": "git",
    "url": "https://github.com/EvoMap/gep-sdk-js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "dependencies": {}
